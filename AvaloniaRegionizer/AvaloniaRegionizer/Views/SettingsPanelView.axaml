<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AvaloniaRegionizer.ViewModels"
             xmlns:views="clr-namespace:AvaloniaRegionizer.Views"
             x:Class="AvaloniaRegionizer.Views.SettingsPanelView"
             x:DataType="vm:MainViewModel"
             x:CompileBindings="False">
    <Border Classes="panel" Padding="12">
        <ScrollViewer>
            <StackPanel Spacing="10">
                <TextBlock Text="{Binding SelectedSettingsSection.Title}" Classes="sectionTitle"/>

                <StackPanel Spacing="8" IsVisible="{Binding IsInputOutputSectionSelected}">
                    <views:SettingsRow Label="{Binding L[Mask]}">
                        <views:SettingsRow.Value>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                <TextBox Text="{Binding MaskPath}" PlaceholderText="{Binding L[Mask]}" ToolTip.Tip="{Binding MaskPath}"/>
                                <Button Grid.Column="1" Content="{Binding L[Browse]}" Command="{Binding BrowseMaskCommand}" MinWidth="76"/>
                            </Grid>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[Output]}">
                        <views:SettingsRow.Value>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                <TextBox Text="{Binding OutputDirectory}" PlaceholderText="{Binding L[Output]}" ToolTip.Tip="{Binding OutputDirectory}"/>
                                <Button Grid.Column="1" Content="{Binding L[Browse]}" Command="{Binding BrowseOutputCommand}" MinWidth="76"/>
                            </Grid>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[Language]}">
                        <views:SettingsRow.Value>
                            <ComboBox ItemsSource="{Binding LanguageOptions}" SelectedItem="{Binding SelectedLanguage}"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[Theme]}">
                        <views:SettingsRow.Value>
                            <ComboBox ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding SelectedTheme}"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                </StackPanel>

                <StackPanel Spacing="8" IsVisible="{Binding IsGenerationSectionSelected}">
                    <views:SettingsRow Label="{Binding L[Seed]}">
                        <views:SettingsRow.Value>
                            <StackPanel Spacing="6">
                                <TextBox Text="{Binding SeedText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="{Binding L[Seed]}"/>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button Content="{Binding L[Randomize]}" Command="{Binding RandomizeSeedCommand}"/>
                                    <Button Content="{Binding L[Copy]}" Command="{Binding CopySeedCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[Projection]}">
                        <views:SettingsRow.Value>
                            <ComboBox ItemsSource="{Binding ProjectionModes}" SelectedItem="{Binding ProjectionMode}"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[PixelSize]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding PixelSize}" Minimum="0.01" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[SimplifyTolerance]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding SimplifyTolerance}" Minimum="0" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <Button Content="{Binding L[RunRegionsOnly]}" Command="{Binding RunRegionsOnlyCommand}" IsEnabled="{Binding !IsGenerating}" HorizontalAlignment="Stretch"/>
                </StackPanel>

                <StackPanel Spacing="8" IsVisible="{Binding IsQualityProfileSectionSelected}">
                    <UniformGrid Columns="2" Rows="2">
                        <Button Classes="preset" Command="{Binding ApplyFastPresetCommand}" Margin="0,0,6,6">
                            <TextBlock Text="{Binding L[FastPreview]}" TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>
                        <Button Classes="preset" Command="{Binding ApplyBalancedPresetCommand}" Margin="0,0,0,6">
                            <TextBlock Text="{Binding L[Balanced]}" TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>
                        <Button Classes="preset" Command="{Binding ApplyDetailedPresetCommand}" Margin="0,0,6,0">
                            <TextBlock Text="{Binding L[Detailed]}" TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>
                        <Button Classes="preset" Command="{Binding ApplyDiagnosticPresetCommand}">
                            <TextBlock Text="{Binding L[DiagnosticExport]}" TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>
                    </UniformGrid>
                </StackPanel>

                <StackPanel Spacing="8" IsVisible="{Binding IsMaskSectionSelected}">
                    <views:SettingsRow Label="{Binding L[OceanSeaMinAreaRatio]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding OceanSeaMinAreaRatio}" Minimum="0" Maximum="1" FormatString="N3"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[InlandSeaMinAreaRatio]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding InlandSeaMinAreaRatio}" Minimum="0" Maximum="1" FormatString="N3"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[OceanSeaNearOceanDistance]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding OceanSeaNearOceanMaxDistanceCells}" Minimum="0"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <CheckBox Content="{Binding L[PreserveOceanCoastline]}" IsChecked="{Binding PreserveOceanCoastline}"/>
                    <CheckBox Content="{Binding L[PreserveInlandWaterMask]}" IsChecked="{Binding PreserveInlandWaterMask}"/>
                </StackPanel>

                <StackPanel Spacing="8" IsVisible="{Binding IsReliefSectionSelected}">
                    <views:SettingsRow Label="{Binding L[ReliefScale]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding ReliefScale}" Minimum="0" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[Mountaininess]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding Mountaininess}" Minimum="0" Maximum="1" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[Roughness]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding Roughness}" Minimum="0" Maximum="1" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[SeaDepthScale]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding SeaDepthScale}" Minimum="0" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[MaxElevation]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding MaxElevationMeters}" Minimum="1"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[MinOceanDepth]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding MinOceanDepthMeters}" Maximum="-1"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <CheckBox Content="{Binding L[PreserveCoastline]}" IsChecked="{Binding PreserveMaskCoastline}"/>
                </StackPanel>

                <StackPanel Spacing="8" IsVisible="{Binding IsWaterRiversSectionSelected}">
                    <views:SettingsRow Label="{Binding L[RiverDensity]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding RiverDensity}" Minimum="0" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[MajorRiverCountMultiplier]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding MajorRiverCountMultiplier}" Minimum="0" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[TributaryDensity]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding TributaryDensity}" Minimum="0" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[MeanderStrength]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding MeanderStrength}" Minimum="0" Maximum="1" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[ChannelCurvatureStrength]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding ChannelCurvatureStrength}" Minimum="0" Maximum="2" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <CheckBox Content="{Binding L[GenerateSmallLakes]}" IsChecked="{Binding GenerateSmallLakes}"/>
                    <CheckBox Content="{Binding L[PreserveRiverCoastline]}" IsChecked="{Binding PreserveRiverCoastline}"/>
                    <CheckBox Content="{Binding L[AllowRiverCarving]}" IsChecked="{Binding AllowRiverCarving}"/>
                </StackPanel>

                <StackPanel Spacing="8" IsVisible="{Binding IsClimateSectionSelected}">
                    <views:SettingsRow Label="{Binding L[ClimatePolarLatitudeMargin]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding ClimatePolarLatitudeMargin}" Minimum="0" Maximum="0.99" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[ClimateEquatorTemperature]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding ClimateEquatorTemperatureCelsius}" FormatString="N1"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[ClimatePoleCooling]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding ClimatePoleCoolingCelsius}" Minimum="0" FormatString="N1"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[ClimateLapseRate]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding ClimateLapseRateCelsiusPerMeter}" Minimum="0" Increment="0.0001" FormatString="N4"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[ClimateOrographicStrength]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding ClimateOrographicStrength}" Minimum="0" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                </StackPanel>

                <StackPanel Spacing="8" IsVisible="{Binding IsBiomesSectionSelected}">
                    <views:SettingsRow Label="{Binding L[ClimateRiverMoistureBonus]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding ClimateRiverMoistureBonus}" Minimum="0" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[ClimateRiverAgricultureBonus]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding ClimateRiverAgricultureBonus}" Minimum="0" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[ClimateSnowMeltThreshold]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding ClimateSnowMeltThresholdCelsius}" FormatString="N1"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[ClimateSnowPrecipitationScale]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding ClimateSnowPrecipitationScale}" Minimum="0" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                </StackPanel>

                <StackPanel Spacing="8" IsVisible="{Binding IsRegionsSectionSelected}">
                    <views:SettingsRow Label="{Binding L[RegionSize]}" Tip="{Binding L[HelpRegionSize]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding TargetArea, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="1"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[PointsMultiplier]}" Tip="{Binding L[HelpPointsMultiplier]}">
                        <views:SettingsRow.Value>
                            <Grid ColumnDefinitions="100,104" ColumnSpacing="8">
                                <Slider Value="{Binding PointsMultiplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="0.5" Maximum="8" TickFrequency="0.1"/>
                                <NumericUpDown Grid.Column="1" Value="{Binding PointsMultiplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="0.01" FormatString="N2"/>
                            </Grid>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <CheckBox Content="{Binding L[DistortionEnabled]}" IsChecked="{Binding BoundaryDistortionEnabled}" ToolTip.Tip="{Binding L[HelpDistortionEnabled]}"/>
                    <views:SettingsRow Label="{Binding L[BoundaryDetail]}" Tip="{Binding L[HelpBoundaryDetail]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding BoundaryDetail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="0.01" Maximum="1" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                </StackPanel>

                <StackPanel Spacing="8" IsVisible="{Binding IsExportSectionSelected}">
                    <views:SettingsRow Label="{Binding L[ExportScale]}" Tip="{Binding L[HelpExportScale]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding ExportScale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="0.01" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[ExportRegionBorderWidth]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding ExportRegionBorderWidth}" Minimum="0" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[ExportTectonicBoundaryWidth]}">
                        <views:SettingsRow.Value>
                            <NumericUpDown Value="{Binding ExportTectonicBoundaryWidth}" Minimum="0" FormatString="N2"/>
                        </views:SettingsRow.Value>
                    </views:SettingsRow>
                    <CheckBox Content="{Binding L[ExportElevationHillshade]}" IsChecked="{Binding ExportDrawElevationHillshade}"/>
                    <CheckBox Content="{Binding L[ExportClimateHillshade]}" IsChecked="{Binding ExportDrawClimateHillshade}"/>
                    <CheckBox Content="{Binding L[ExportClimateRivers]}" IsChecked="{Binding ExportDrawClimateRivers}"/>
                    <Button Content="{Binding L[ExportPreview]}" Command="{Binding ExportPreviewCommand}" IsEnabled="{Binding !IsGenerating}" HorizontalAlignment="Stretch"/>
                </StackPanel>

                <StackPanel Spacing="8" IsVisible="{Binding IsTectonicsSectionSelected}">
                    <views:SettingsRow Label="{Binding L[PlateCount]}"><views:SettingsRow.Value><NumericUpDown Value="{Binding PlateCount}" Minimum="1"/></views:SettingsRow.Value></views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[HotspotCount]}"><views:SettingsRow.Value><NumericUpDown Value="{Binding HotspotCount}" Minimum="0"/></views:SettingsRow.Value></views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[ContinentalSeedRatio]}"><views:SettingsRow.Value><NumericUpDown Value="{Binding ContinentalSeedRatio}" Minimum="0" Maximum="1" FormatString="N2"/></views:SettingsRow.Value></views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[BoundaryNoise]}"><views:SettingsRow.Value><NumericUpDown Value="{Binding BoundaryNoise}" Minimum="0" Maximum="1" FormatString="N2"/></views:SettingsRow.Value></views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[Activity]}"><views:SettingsRow.Value><NumericUpDown Value="{Binding Activity}" Minimum="0" Maximum="2" FormatString="N2"/></views:SettingsRow.Value></views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[EarthLikeFactor]}"><views:SettingsRow.Value><NumericUpDown Value="{Binding EarthLikeFactor}" Minimum="0" Maximum="1" FormatString="N2"/></views:SettingsRow.Value></views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[HistoryDepth]}"><views:SettingsRow.Value><NumericUpDown Value="{Binding HistoryDepth}" Minimum="0" Maximum="1" FormatString="N2"/></views:SettingsRow.Value></views:SettingsRow>
                    <CheckBox Content="{Binding L[ValidateGeometry]}" IsChecked="{Binding ValidateGeometry}"/>
                </StackPanel>

                <StackPanel Spacing="8" IsVisible="{Binding IsErosionSectionSelected}">
                    <views:SettingsRow Label="{Binding L[Erosion]}"><views:SettingsRow.Value><NumericUpDown Value="{Binding Erosion}" Minimum="0" Maximum="1" FormatString="N2"/></views:SettingsRow.Value></views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[SmallLakeCountMultiplier]}"><views:SettingsRow.Value><NumericUpDown Value="{Binding SmallLakeCountMultiplier}" Minimum="0" FormatString="N2"/></views:SettingsRow.Value></views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[SmallLakeScatterMultiplier]}"><views:SettingsRow.Value><NumericUpDown Value="{Binding SmallLakeScatterMultiplier}" Minimum="0" FormatString="N2"/></views:SettingsRow.Value></views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[SmallLakeSizeMultiplier]}"><views:SettingsRow.Value><NumericUpDown Value="{Binding SmallLakeSizeMultiplier}" Minimum="0" FormatString="N2"/></views:SettingsRow.Value></views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[LakeSurfacePercentile]}"><views:SettingsRow.Value><NumericUpDown Value="{Binding LakeSurfacePercentile}" Minimum="0" Maximum="1" FormatString="N2"/></views:SettingsRow.Value></views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[EndorheicBasinChance]}"><views:SettingsRow.Value><NumericUpDown Value="{Binding EndorheicBasinChance}" Minimum="0" Maximum="1" FormatString="N2"/></views:SettingsRow.Value></views:SettingsRow>
                </StackPanel>

                <StackPanel Spacing="8" IsVisible="{Binding IsDiagnosticsSectionSelected}">
                    <views:SettingsRow Label="{Binding L[TectonicJson]}"><views:SettingsRow.Value><ComboBox ItemsSource="{Binding TectonicJsonModes}" SelectedItem="{Binding TectonicJsonMode}"/></views:SettingsRow.Value></views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[ElevationJson]}"><views:SettingsRow.Value><ComboBox ItemsSource="{Binding ElevationJsonModes}" SelectedItem="{Binding ElevationJsonMode}"/></views:SettingsRow.Value></views:SettingsRow>
                    <views:SettingsRow Label="{Binding L[ClimateJson]}"><views:SettingsRow.Value><ComboBox ItemsSource="{Binding ClimateJsonModes}" SelectedItem="{Binding ClimateJsonMode}"/></views:SettingsRow.Value></views:SettingsRow>
                    <TextBlock Text="{Binding ValidationMessage}" Foreground="#EF4444" TextWrapping="Wrap" IsVisible="{Binding HasValidationMessage}"/>
                    <TextBlock Text="{Binding ArtifactSummary}" TextWrapping="Wrap" Opacity="0.8" IsVisible="{Binding HasArtifacts}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
