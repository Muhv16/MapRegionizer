<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AvaloniaRegionizer.Views"
             x:Class="AvaloniaRegionizer.Views.SettingsRow"
             x:DataType="views:SettingsRow"
             x:CompileBindings="False">
    <Grid ColumnDefinitions="170,*" ColumnSpacing="12" MinHeight="34" Margin="0,2">
        <TextBlock Text="{Binding Label, RelativeSource={RelativeSource AncestorType=views:SettingsRow}}"
                   ToolTip.Tip="{Binding Tip, RelativeSource={RelativeSource AncestorType=views:SettingsRow}}"
                   Foreground="{Binding DataContext.SecondaryText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"/>
        <ContentControl Grid.Column="1"
                        Content="{Binding Value, RelativeSource={RelativeSource AncestorType=views:SettingsRow}}"/>
    </Grid>
</UserControl>
